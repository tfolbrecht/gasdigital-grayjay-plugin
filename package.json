{
  "name": "grayjay-gasdigital",
  "private": true,
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git@github.com:tfolbrecht/gasdigital-grayjay-plugin.git"
  },
  "homepage": "https://tfolbrecht.github.io/gasdigital-grayjay-plugin/",
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/sign.mjs && node scripts/validate-dist.mjs",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "keygen": "node scripts/keygen.mjs",
    "sign": "node scripts/sign.mjs",
    "validate": "node scripts/validate-dist.mjs",
    "serve": "node scripts/serve.mjs",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "http-server": "^14.1.1",
    "qrcode": "^1.5.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
